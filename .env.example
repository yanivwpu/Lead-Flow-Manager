# WhachatCRM / Lead-Flow-Manager — Railway & local reference
# Copy to .env and fill in. Never commit real secrets.

# --- Core / Neon ---
DATABASE_URL=
# Dedicated Postgres for integration tests (preferred over ALLOW_DB_TEST_WRITES)
TEST_DATABASE_URL=
# Set to 1 to allow tests/scripts to write to DATABASE_URL when TEST_DATABASE_URL is unset (dev only)
ALLOW_DB_TEST_WRITES=
SESSION_SECRET=
PORT=5000
NODE_ENV=development

# Public URLs (production: https://app.whachatcrm.com and https://www.whachatcrm.com)
APP_URL=
MARKETING_URL=

# --- Client (Vite) ---
# GA4 measurement ID (defaults to G-6Y1CWBVBHL in cookieConsent.ts if unset)
VITE_GA_MEASUREMENT_ID=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Stripe (non-Shopify billing) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_AI_BRAIN_MONTHLY_PRICE_ID=
STRIPE_RGE_ONE_TIME_PRICE_ID=

# --- Shopify app (App Pricing / Managed Pricing / OAuth) ---
SHOPIFY_APP_HOST=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# App handle from shopify.app.toml (plan selection URL: admin.shopify.com/store/{shop}/charges/{handle}/pricing_plans)
SHOPIFY_APP_HANDLE=whachatcrm
# Client: same handle for building plan selection URLs in-browser
VITE_SHOPIFY_APP_HANDLE=whachatcrm
# Client: public Shopify App Store listing URL (omit or leave empty while the app is in review — UI uses private install flow)
VITE_SHOPIFY_APP_STORE_URL=
# Client: HTTPS install link from your team (used when App Store URL is missing or listing check fails / 404)
VITE_SHOPIFY_MANUAL_INSTALL_URL=

# --- Go High Level / LeadConnector (internal env names) ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# OAuth redirect for Marketplace install callback (defaults to {APP_URL}/api/ext/callback)
GHL_REDIRECT_URI=
# Marketplace app version id from GHL developer portal (required for install URL)
GHL_APP_VERSION_ID=
# Optional: full install URL override (must match GHL_CLIENT_ID). Prefer GHL_APP_VERSION_ID instead.
GHL_MARKETPLACE_INSTALL_URL=
# Optional: space-separated OAuth scopes (defaults to standard CRM scopes)
GHL_OAUTH_SCOPES=
# Optional: chooselocation base (default marketplace.leadconnectorhq.com; try marketplace.gohighlevel.com if needed)
GHL_OAUTH_CHOOSELOCATION_BASE=
# Deprecated client-side override — install URL is served from GET /api/ext/marketplace-install
VITE_LEADCONNECTOR_INSTALL_URL=
# Optional: protect admin GHL maintenance routes (header)
GHL_ADMIN_KEY=
# Internal Growth Tools — prospect import destination (YaBa workspace)
PROSPECT_IMPORT_DESTINATION_USER_ID=
PROSPECT_IMPORT_DESTINATION_EMAIL=yahabegood@gmail.com
PROSPECT_IMPORT_ALLOWED_EMAILS=yahabegood@gmail.com,yanivharamaty@gmail.com
# Optional extra emails for GHL OAuth token recovery (union with PROSPECT_IMPORT_ALLOWED_EMAILS)
# GHL_OAUTH_RECOVERY_ALLOWED_EMAILS=

# --- Meta (WhatsApp / Facebook / Instagram) ---
# WhatsApp Embedded Signup MUST use META_APP_ID (not INSTAGRAM_APP_ID).
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=
# OAuth redirect for Embedded Signup (must match Meta app settings + FB.login)
META_WHATSAPP_REDIRECT_URI=
# Facebook Login for Business → Configurations → WhatsApp Embedded Signup variation (not General login).
# Production (app 810621184995059): 1774700346847063 — replaces deprecated General config 1334305135262470.
META_WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=1774700346847063
# Optional: separate coexistence Embedded Signup configuration
# META_WHATSAPP_COEXISTENCE_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_ENABLED=true
# WHATSAPP_COEXISTENCE_ENABLED=true

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Redis (BullMQ / queue) ---
REDIS_URL=

# --- Cloudflare R2 (media storage) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# --- RGE Inventory Connector (Phase 1 — MLS listing sync) ---
# Enable inventory APIs (still requires RGE template install per workspace)
INVENTORY_CONNECTOR_ENABLED=0
# Optional: sandbox/dev token for local MLS Grid scripts (per-user tokens live in DB)
MLS_GRID_ACCESS_TOKEN=
