# WhachatCRM / Lead-Flow-Manager — Railway & local reference
# Copy to .env and fill in. Never commit real secrets.

# --- Core / Neon ---
DATABASE_URL=
SESSION_SECRET=
PORT=5000
NODE_ENV=development

# Public URLs (production: https://app.whachatcrm.com and https://www.whachatcrm.com)
APP_URL=
MARKETING_URL=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Stripe (non-Shopify billing) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_YEARLY_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_AI_BRAIN_MONTHLY_PRICE_ID=
STRIPE_RGE_ONE_TIME_PRICE_ID=

# --- Shopify app (App Pricing / Managed Pricing / OAuth) ---
SHOPIFY_APP_HOST=
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# App handle from shopify.app.toml (plan selection URL: admin.shopify.com/store/{shop}/charges/{handle}/pricing_plans)
SHOPIFY_APP_HANDLE=whachatcrm
# Client: same handle for building plan selection URLs in-browser
VITE_SHOPIFY_APP_HANDLE=whachatcrm
# Client: public Shopify App Store listing URL (omit or leave empty while the app is in review — UI uses private install flow)
VITE_SHOPIFY_APP_STORE_URL=
# Client: HTTPS install link from your team (used when App Store URL is missing or listing check fails / 404)
VITE_SHOPIFY_MANUAL_INSTALL_URL=

# --- Go High Level / LeadConnector ---
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
# OAuth redirect for LeadConnector / Marketplace install callback (defaults to {APP_URL}/api/ext/callback)
GHL_REDIRECT_URI=
# Optional: direct “Install / open marketplace” link for the Integrations UI (defaults to marketplace.gohighlevel.com)
VITE_LEADCONNECTOR_INSTALL_URL=
# Optional: protect admin GHL maintenance routes (header)
GHL_ADMIN_KEY=

# --- Meta (WhatsApp / Facebook / Instagram) ---
# WhatsApp Embedded Signup MUST use META_APP_ID (not INSTAGRAM_APP_ID).
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=
# OAuth redirect for Embedded Signup (must match Meta app settings + FB.login)
META_WHATSAPP_REDIRECT_URI=
# Dedicated Embedded Signup configuration id from Meta App Dashboard (not coexistence, not META_CONFIG_ID legacy)
META_WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=
# Optional: separate coexistence Embedded Signup configuration
# META_WHATSAPP_COEXISTENCE_CONFIG_ID=
WHATSAPP_EMBEDDED_SIGNUP_ENABLED=true
# WHATSAPP_COEXISTENCE_ENABLED=true

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Redis (BullMQ / queue) ---
REDIS_URL=

# --- Cloudflare R2 (media storage) ---
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_URL=

# --- RGE Inventory Connector (Phase 1 — MLS listing sync) ---
# Enable inventory APIs (still requires RGE template install per workspace)
INVENTORY_CONNECTOR_ENABLED=0
# Optional: sandbox/dev token for local MLS Grid scripts (per-user tokens live in DB)
MLS_GRID_ACCESS_TOKEN=
